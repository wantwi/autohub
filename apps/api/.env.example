NODE_ENV=development
PORT=3000
# Supabase on Windows: direct db.*.supabase.co is often IPv6-only — use Session pooler (Dashboard → Connect).
# Username is postgres.YOUR_PROJECT_REF (not just postgres). Match REGION to Project Settings → General.
DATABASE_URL=postgresql://postgres:ZBRe9hSvKXPwfhmeZBRe9hSvKXPwfhme@db.uwpcspqjsvhazctrgklg.supabase.co:5432/postgres
# Optional: ms to wait while opening each new pool connection (default 120000). Raise if you see
# "Connection terminated due to connection timeout" with cause "Connection terminated unexpectedly"
# on slow VPNs or Supabase pooler TLS handshakes.
# DATABASE_CONNECTION_TIMEOUT_MS=180000
# Optional: longer timeout only for npm run apply-schema (default 180000 ms)
# APPLY_SCHEMA_TIMEOUT_MS=240000
# Idle pooled PG clients: default 0 = keep until process exit (fast repeat requests to Supabase).
# Set e.g. 300000 (5 min) if you need to cap idle connections on shared hosting.
# DATABASE_POOL_IDLE_TIMEOUT_MS=0
# Dev only (corporate proxy / SSL inspection): never use in production
# DATABASE_SSL_NO_VERIFY=1
# If pooler works by hostname but times out on IPv6, try (can cause ECONNRESET on some networks — omit if so):
# DATABASE_PG_RESOLVE_IPV4=1
JWT_SECRET=change-me-min-32-chars-for-hs256-secret-key
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173,http://localhost:5176,http://127.0.0.1:5173,http://127.0.0.1:5176

# OTP: set DEV_OTP=123456 to skip SMS and accept this code (local only)
DEV_OTP=

AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_SENDER_ID=AutoHub

PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_WEBHOOK_SECRET=

GOOGLE_CLIENT_ID=

# Cloudinary (for server-side image deletion)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@autohub.com
